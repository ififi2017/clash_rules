# Fix_Google_Play — Method 4: both domains via DIRECT
#
# services.googleapis.cn via DIRECT → Google returns CN CDN URL
# xn--ngstr-lra8j.com   via DIRECT → CN CDN is directly accessible
#
# Both must take the same path (both DIRECT or both proxy).
# Explicit DIRECT here ensures these rules fire before geolocation-!cn
# would otherwise send xn--ngstr-lra8j.com through proxy.
DOMAIN-SUFFIX,xn--ngstr-lra8j.com
DOMAIN-SUFFIX,googleapis.cn
DOMAIN,clientservices.googleapis.com
DOMAIN,update.googleapis.com
DOMAIN,fonts.googleapis.com
